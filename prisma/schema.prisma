generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Registration {
  id                String   @id @default(cuid())
  trackingId        String   @unique
  firstName         String
  lastName          String
  dateOfBirth       String   @default("")
  gender            String   @default("")
  nationality       String   @default("")
  nidPassportType   String   @default("NID")
  nidPassportNumber String   @default("")
  email             String
  phone             String
  address           String   @default("")
  city              String   @default("")
  state             String   @default("")
  postalCode        String   @default("")
  country           String   @default("")
  occupation        String   @default("")
  company           String   @default("")
  experience        String   @default("")
  skills            String   @default("")
  department        String   @default("")
  photoPath         String?
  cvPath            String?
  nidPassportPath   String?
  signatureData     String   @default("")
  agreeToTerms      Boolean  @default(false)
  agreeToPrivacy    Boolean  @default(false)
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
